@page "/account/login"
@layout AuthLayout
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser>   UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ILoginTicketService            TicketService
@inject NavigationManager              Navigation

<div class="auth-logo">
    <img src="favicon.png" alt="logo" />
    <span class="auth-logo-text">BIM XÂY DỰNG 360</span>
</div>

<div class="auth-card">
    <h1 class="auth-card-title">ĐĂNG NHẬP</h1>

    @* ── Alert banner: sai credentials hoặc tài khoản bị khoá ── *@
    @if (!string.IsNullOrEmpty(_alertMessage))
    {
        <div class="auth-alert-error">
            <span class="auth-alert-icon">⚠</span>
            <span class="auth-alert-text">@_alertMessage</span>
            <button type="button" class="auth-alert-close"
                    @onclick="() => _alertMessage = string.Empty">×</button>
        </div>
    }

    <EditForm EditContext="_editContext" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />

        @* ── Email ── *@
        <div class="auth-field">
            <label>Email <span class="required-star">*</span></label>
            <InputText @bind-Value="_model.Email"
                       class="auth-input"
                       placeholder="Nhập email"
                       autocomplete="email" />
            <ValidationMessage For="@(() => _model.Email)" />
        </div>

        @* ── Mật khẩu ── *@
        <div class="auth-field">
            <label>Mật khẩu <span class="required-star">*</span></label>
            <div class="auth-input-password-wrapper">
                <input type="@(_showPassword ? "text" : "password")"
                       value="@_model.Password"
                       @oninput="OnPasswordInput"
                       @onblur="OnPasswordBlur"
                       class="auth-input @GetPasswordCss()"
                       placeholder="Nhập mật khẩu"
                       autocomplete="current-password" />
                <button type="button" class="toggle-password"
                        @onclick="() => _showPassword = !_showPassword"
                        tabindex="-1">
                    @if (_showPassword)
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    }
                    else
                    {
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
                            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
                            <line x1="1" y1="1" x2="23" y2="23" />
                        </svg>
                    }
                </button>
            </div>
            <ValidationMessage For="@(() => _model.Password)" />
        </div>

        @* ── Remember me + Quên mật khẩu ── *@
        <div class="auth-remember-row">
            <label class="auth-checkbox-label">
                <InputCheckbox @bind-Value="_model.RememberMe" class="auth-checkbox" />
                <span>Ghi nhớ đăng nhập</span>
            </label>
            <a href="/account/forgot-password" class="auth-forgot-link">Quên mật khẩu?</a>
        </div>

        @* ── Nút Đăng nhập ── *@
        <div style="margin-top: 24px;">
            <button type="submit" class="btn-auth-primary" disabled="@_isSubmitting">
                @if (_isSubmitting)
                {
                    <span class="btn-spinner"></span>
                }
                Đăng nhập
            </button>
        </div>
    </EditForm>

    @* ── Footer links ── *@
    <div class="auth-login-footer">
        <span class="auth-footer-link" style="margin-top:0;">
            Bạn chưa có tài khoản? <a href="/account/register">Đăng ký</a>
        </span>
        <a href="tel:+84" class="auth-support-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px;">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.61 19.27
                         19.79 19.79 0 0 1 4.73 12.39a19.79 19.79 0 0 1-2.65-8.19
                         A2 2 0 0 1 4.06 2h3a2 2 0 0 1 2 1.72
                         c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91
                         a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45
                         c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
            Liên hệ hỗ trợ
        </a>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error     { get; set; }

    private readonly LoginDto _model = new();
    private EditContext        _editContext = default!;

    private bool   _showPassword;
    private bool   _isSubmitting;
    private string _alertMessage = string.Empty;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);

        _alertMessage = Error switch
        {
            "expired"  => "Phiên đăng nhập đã hết hạn. Vui lòng thử lại.",
            "inactive" => "Tài khoản của bạn đã bị vô hiệu hoá.",
            _          => string.Empty
        };
    }

    private void OnPasswordInput(ChangeEventArgs e)
    {
        _model.Password = e.Value?.ToString() ?? string.Empty;
        _editContext.NotifyFieldChanged(_editContext.Field(nameof(LoginDto.Password)));
    }

    private void OnPasswordBlur()
    {
        _editContext.NotifyFieldChanged(_editContext.Field(nameof(LoginDto.Password)));
    }

    private string GetPasswordCss()
    {
        var fi = _editContext.Field(nameof(LoginDto.Password));
        if (!_editContext.IsModified(fi)) return string.Empty;
        return _editContext.GetValidationMessages(fi).Any() ? "invalid" : string.Empty;
    }

    private async Task HandleLogin()
    {
        _isSubmitting = true;
        _alertMessage = string.Empty;
        StateHasChanged();

        try
        {
            var user = await UserManager.FindByEmailAsync(_model.Email);

            if (user is null || !user.IsActive)
            {
                _alertMessage = "Email hoặc mật khẩu không chính xác. Vui lòng kiểm tra lại.";
                return;
            }

            if (await UserManager.IsLockedOutAsync(user))
            {
                var until = user.LockoutEnd!.Value.LocalDateTime.ToString("HH:mm");
                _alertMessage = $"Tài khoản tạm thời bị khoá do đăng nhập sai nhiều lần. Vui lòng thử lại sau {until}.";
                return;
            }

            var passwordOk = await UserManager.CheckPasswordAsync(user, _model.Password);

            if (!passwordOk)
            {
                await UserManager.AccessFailedAsync(user);

                if (await UserManager.IsLockedOutAsync(user))
                {
                    _alertMessage = "Tài khoản tạm thời bị khoá do đăng nhập sai quá 5 lần. Vui lòng thử lại sau 15 phút.";
                }
                else
                {
                    _alertMessage = "Email hoặc mật khẩu không chính xác. Vui lòng kiểm tra lại.";
                }
                return;
            }

            await UserManager.ResetAccessFailedCountAsync(user);

            var ticket = TicketService.CreateTicket(user.Id, _model.RememberMe);
            var callbackUrl = string.IsNullOrEmpty(ReturnUrl)
                ? $"/account/login-callback?ticket={ticket}"
                : $"/account/login-callback?ticket={ticket}&returnUrl={Uri.EscapeDataString(ReturnUrl)}";

            Navigation.NavigateTo(callbackUrl, forceLoad: true);
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
