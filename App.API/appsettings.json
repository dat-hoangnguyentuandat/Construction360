{
    "ConnectionStrings": {
        "DefaultConnection": "Host=localhost;Port=5432;Database=construction360_Clone;Username=postgres;Password=dat13032004"
    },
    "AllowedHosts": "*",
    "Serilog": {
        "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.EntityFrameworkCore": "Warning",
                "System": "Warning",
                "OpenIddict": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/app/app-.log",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 90,
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/errors/error-.log",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 90,
                    "restrictedToMinimumLevel": "Warning",
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "logs/audit/audit-.log",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 365,
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] {Message:lj}{NewLine}{Exception}"
                }
            }
        ],
        "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId" ]
    },
    "OpenIddict": {
        "TokenLifetimes": {
            "AccessTokenSeconds": 30,
            "RefreshTokenDays": 30,
            "AuthorizationCodeMinutes": 5
        },
        "Scopes": [
            { "Name": "email", "DisplayName": "Email" },
            { "Name": "profile", "DisplayName": "Profile" },
            { "Name": "roles", "DisplayName": "Roles" },
            { "Name": "offline_access", "DisplayName": "Offline Access" }
        ],
        "Applications": {
            "AppWeb": {
                "ClientId": "app-web",
                "ClientSecret": "app-web-secret",
                "DisplayName": "App Web Client",
                "RedirectUris": [ "https://localhost:7066/signin-oidc" ],
                "PostLogoutRedirectUris": [ "https://localhost:7066/signout-callback-oidc" ],
                "Requirements": [ "ft:pkce" ],
                "Permissions": [
                    "gt:authorization_code",
                    "gt:refresh_token",
                    "gt:password",
                    "rst:code",
                    "ept:authorization",
                    "ept:token",
                    "ept:logout",
                    "scp:email",
                    "scp:profile",
                    "scp:roles",
                    "scp:offline_access"
                ]
            }
        }
    }
}
