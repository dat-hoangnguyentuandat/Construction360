@page "/account/forgot-password"
@model App.API.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="auth-logo">
    <img src="/favicon.png" alt="logo" />
    <span class="auth-logo-text">BIM XÂY DỰNG 360</span>
</div>

<div class="auth-card">
    <h1 class="auth-card-title">QUÊN MẬT KHẨU</h1>

    @if (Model.ShowSuccess)
    {
        <div class="auth-alert-success">
            <span class="auth-alert-icon">✓</span>
            <span class="auth-alert-text">Mật khẩu đã được đặt lại thành công.</span>
        </div>
        <div style="margin-top: 24px;">
            <a href="/account/login" class="btn-auth-primary" style="display:block;text-align:center;">
                Quay lại đăng nhập
            </a>
        </div>
    }
    else if (Model.EmailFound)
    {
        <p style="color:#888;margin-bottom:24px;font-size:0.95em;">
            Nhập mật khẩu mới cho tài khoản <strong>@Model.Input.Email</strong>.
        </p>

        <form method="post" asp-page-handler="ResetPassword">
            <input type="hidden" asp-for="Input.Email" />

            <div asp-validation-summary="ModelOnly" class="auth-alert-error"
                 style="display:@(!ViewData.ModelState.IsValid ? "flex" : "none")">
            </div>

            <div class="auth-field">
                <label asp-for="Reset.NewPassword">Mật khẩu mới <span class="required-star">*</span></label>
                <input asp-for="Reset.NewPassword"
                       class="auth-input"
                       placeholder="Nhập mật khẩu mới"
                       type="password" />
                <span asp-validation-for="Reset.NewPassword" class="auth-error-msg"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Reset.ConfirmPassword">Xác nhận mật khẩu <span class="required-star">*</span></label>
                <input asp-for="Reset.ConfirmPassword"
                       class="auth-input"
                       placeholder="Nhập lại mật khẩu mới"
                       type="password" />
                <span asp-validation-for="Reset.ConfirmPassword" class="auth-error-msg"></span>
            </div>

            <div style="margin-top: 24px;">
                <button type="submit" class="btn-auth-primary">
                    Đặt lại mật khẩu
                </button>
            </div>
        </form>
    }
    else
    {
        <p style="color:#888;margin-bottom:24px;font-size:0.95em;">
            Nhập email đăng ký của bạn để đặt lại mật khẩu.
        </p>

        <form method="post" asp-page-handler="CheckEmail">
            <div asp-validation-summary="ModelOnly" class="auth-alert-error"
                 style="display:@(!ViewData.ModelState.IsValid ? "flex" : "none")">
            </div>

            <div class="auth-field">
                <label asp-for="Input.Email">Email <span class="required-star">*</span></label>
                <input asp-for="Input.Email"
                       class="auth-input"
                       placeholder="Nhập email của bạn"
                       type="email" />
                <span asp-validation-for="Input.Email" class="auth-error-msg"></span>
            </div>

            <div style="margin-top: 24px;">
                <button type="submit" class="btn-auth-primary">
                    Tiếp theo
                </button>
            </div>
        </form>
        <div class="auth-login-footer">
            <div class="auth-footer-link">
                <a href="/account/login">← Quay lại đăng nhập</a>
            </div>
        </div>
    }
</div>
