@page "/account/forgot-password"
@layout AuthLayout
@using Construction360.Models
@using Construction360.Services
@using Microsoft.AspNetCore.Identity
@using OpenIddict.Abstractions
@implements IDisposable

@inject UserManager<ApplicationUser>    UserManager
@inject ForgotPasswordOtpService        OtpService
@inject IEmailSender                    EmailSender
@inject IOpenIddictTokenManager         TokenManager
@inject NavigationManager               Navigation

<div class="auth-logo">
    <img src="favicon.png" alt="logo" />
    <span class="auth-logo-text">BIM XÂY DỰNG 360</span>
</div>

@if (_step == 1)
{
    <!-- ══════════════════════════════════════════
         STEP 1 — Nhập email
    ═══════════════════════════════════════════ -->
    <div class="auth-card">
        <h1 class="auth-card-title">QUÊN MẬT KHẨU</h1>

        <p class="auth-description">
            Vui lòng nhập email đã liên kết với tài khoản của bạn để nhận mã xác thực.
        </p>

        @if (!string.IsNullOrEmpty(_step1Alert))
        {
            <div class="auth-alert-error">
                <span class="auth-alert-icon">⚠</span>
                <span class="auth-alert-text">@_step1Alert</span>
                <button type="button" class="auth-alert-close"
                        @onclick="() => _step1Alert = string.Empty">×</button>
            </div>
        }

        <EditForm EditContext="_editContext1" OnValidSubmit="HandleSendOtp">
            <DataAnnotationsValidator />

            <div class="auth-field">
                <label>Email <span class="required-star">*</span></label>
                <InputText @bind-Value="_emailModel.Email"
                           class="auth-input"
                           placeholder="Nhập email"
                           autocomplete="email" />
                <ValidationMessage For="@(() => _emailModel.Email)" />
            </div>

            <div class="auth-btn-row" style="margin-top: 24px;">
                <button type="button" class="btn-auth-outline"
                        @onclick="Cancel" disabled="@_isSubmitting">
                    Hủy
                </button>
                <button type="submit" class="btn-auth-primary" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span class="btn-spinner"></span>
                    }
                    Tiếp tục
                </button>
            </div>
        </EditForm>
    </div>
}
else
{
    <!-- ══════════════════════════════════════════
         STEP 2 — Nhập OTP + mật khẩu mới
    ═══════════════════════════════════════════ -->
    <div class="auth-card">
        <h1 class="auth-card-title">TẠO MẬT KHẨU MỚI</h1>

        <p class="auth-description">
            Mã xác thực đã được gửi đến <strong>@_emailModel.Email</strong>
        </p>

        @if (!string.IsNullOrEmpty(_otpError))
        {
            <div class="auth-alert-error">
                <span class="auth-alert-icon">⚠</span>
                <span class="auth-alert-text">@_otpError</span>
                <button type="button" class="auth-alert-close"
                        @onclick="() => _otpError = string.Empty">×</button>
            </div>
        }

        <EditForm EditContext="_editContext2" OnValidSubmit="HandleResetPassword">
            <DataAnnotationsValidator />

            @* ── Mã xác thực ── *@
            <div class="auth-field">
                <label>Mã xác thực <span class="required-star">*</span></label>
                <InputText @bind-Value="_resetModel.Otp"
                           class="auth-input"
                           placeholder="Nhập mã xác thực"
                           maxlength="6"
                           autocomplete="one-time-code" />
                <ValidationMessage For="@(() => _resetModel.Otp)" />
            </div>

            @* ── Mật khẩu mới ── *@
            <div class="auth-field">
                <label>Mật khẩu <span class="required-star">*</span></label>
                <div class="auth-input-password-wrapper">
                    <input type="@(_showPwd1 ? "text" : "password")"
                           value="@_resetModel.Password"
                           @oninput="OnPasswordInput"
                           @onblur="OnPasswordBlur"
                           class="auth-input @GetPwdCss(nameof(ResetPasswordModel.Password))"
                           placeholder="Nhập mật khẩu" />
                    <button type="button" class="toggle-password"
                            @onclick="() => _showPwd1 = !_showPwd1" tabindex="-1">
                        @EyeIcon(_showPwd1)
                    </button>
                </div>
                <ValidationMessage For="@(() => _resetModel.Password)" />
                <div class="auth-hint-msg">
                    Sử dụng tối thiểu 8 ký tự, bao gồm chữ cái, chữ số và ký tự đặc biệt
                </div>
            </div>

            @* ── Nhập lại mật khẩu ── *@
            <div class="auth-field">
                <label>Nhập lại mật khẩu <span class="required-star">*</span></label>
                <div class="auth-input-password-wrapper">
                    <input type="@(_showPwd2 ? "text" : "password")"
                           value="@_resetModel.ConfirmPassword"
                           @oninput="OnConfirmPasswordInput"
                           @onblur="OnConfirmPasswordBlur"
                           class="auth-input @GetPwdCss(nameof(ResetPasswordModel.ConfirmPassword))"
                           placeholder="Nhập lại mật khẩu" />
                    <button type="button" class="toggle-password"
                            @onclick="() => _showPwd2 = !_showPwd2" tabindex="-1">
                        @EyeIcon(_showPwd2)
                    </button>
                </div>
                <ValidationMessage For="@(() => _resetModel.ConfirmPassword)" />
            </div>

            @* ── Buttons ── *@
            <div class="auth-btn-row">
                <button type="button" class="btn-auth-outline"
                        @onclick="BackToStep1" disabled="@_isSubmitting">
                    Quay lại
                </button>
                <button type="submit" class="btn-auth-primary" disabled="@_isSubmitting">
                    @if (_isSubmitting)
                    {
                        <span class="btn-spinner"></span>
                    }
                    Tiếp tục
                </button>
            </div>
        </EditForm>

        @* ── Gửi lại mã ── *@
        <div style="margin-top: 14px; font-size: 0.87rem; color: #6b7280;">
            @if (_resendCooldown > 0)
            {
                <span>Gửi lại sau (<strong>@_resendCooldown</strong>)</span>
            }
            else
            {
                <button type="button" class="btn-link-inline"
                        @onclick="HandleResendOtp" disabled="@_isResending">
                    @if (_isResending)
                    {
                        <span>Đang gửi...</span>
                    }
                    else
                    {
                        <span>Gửi lại mã</span>
                    }
                </button>
            }
        </div>
    </div>
}

@* ── Success modal ── *@
@if (_showSuccessModal)
{
    <div class="auth-modal-overlay">
        <div class="auth-modal">
            <div class="auth-modal-header">
                <div class="auth-modal-title">
                    <span class="success-icon">✓</span>
                    Lưu mật khẩu thành công
                </div>
                <button type="button" class="auth-modal-close"
                        @onclick="OnSuccessOk">×</button>
            </div>
            <div class="auth-modal-footer">
                <button type="button" class="btn-modal-ok"
                        @onclick="OnSuccessOk">OK</button>
            </div>
        </div>
    </div>
}

@code {
    // ── State ───────────────────────────────────────────────────
    private int    _step           = 1;
    private bool   _showPwd1;
    private bool   _showPwd2;
    private bool   _isSubmitting;
    private bool   _isResending;
    private bool   _showSuccessModal;
    private string _step1Alert     = string.Empty;
    private string _otpError       = string.Empty;
    private int    _resendCooldown = 0;

    // ── Models ──────────────────────────────────────────────────
    private readonly ForgotPasswordEmailModel _emailModel = new();
    private          ResetPasswordModel       _resetModel = new();

    // ── EditContexts ────────────────────────────────────────────
    private EditContext _editContext1 = default!;
    private EditContext _editContext2 = default!;

    // ── Countdown timer ─────────────────────────────────────────
    private System.Threading.Timer? _countdownTimer;

    protected override void OnInitialized()
    {
        _editContext1 = new EditContext(_emailModel);
        _editContext2 = new EditContext(_resetModel);
    }

    // ── Step 1: Gửi OTP ─────────────────────────────────────────
    private async Task HandleSendOtp()
    {
        _isSubmitting = true;
        _step1Alert   = string.Empty;
        StateHasChanged();

        try
        {
            var user = await UserManager.FindByEmailAsync(_emailModel.Email);

            // Không tiết lộ email có tồn tại hay không (bảo mật)
            // Nếu không có user, vẫn chuyển sang step 2 nhưng không gửi OTP
            if (user is not null && user.IsActive)
            {
                var (code, success) = OtpService.GenerateOtp(_emailModel.Email, user.Id);
                if (success && code is not null)
                {
                    await EmailSender.SendEmailAsync(
                        _emailModel.Email,
                        "Mã xác thực đặt lại mật khẩu — BIM Xây Dựng 360",
                        $@"<p>Xin chào <strong>{user.FullName ?? user.Email}</strong>,</p>
                           <p>Mã xác thực của bạn là: <strong style='font-size:1.4em;letter-spacing:4px'>{code}</strong></p>
                           <p>Mã có hiệu lực trong <strong>5 phút</strong>. Không chia sẻ mã này cho bất kỳ ai.</p>
                           <p>Nếu bạn không yêu cầu đặt lại mật khẩu, hãy bỏ qua email này.</p>");
                }
            }

            // Chuyển sang step 2 và bắt đầu cooldown
            _resetModel   = new ResetPasswordModel();
            _editContext2 = new EditContext(_resetModel);
            _otpError     = string.Empty;
            _step         = 2;
            StartCooldown();
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    // ── Step 2: Gửi lại OTP ─────────────────────────────────────
    private async Task HandleResendOtp()
    {
        _isResending = true;
        StateHasChanged();

        try
        {
            var user = await UserManager.FindByEmailAsync(_emailModel.Email);
            if (user is not null && user.IsActive)
            {
                var (code, success) = OtpService.GenerateOtp(_emailModel.Email, user.Id);
                if (success && code is not null)
                {
                    await EmailSender.SendEmailAsync(
                        _emailModel.Email,
                        "Mã xác thực đặt lại mật khẩu — BIM Xây Dựng 360",
                        $@"<p>Mã xác thực mới của bạn là: <strong style='font-size:1.4em;letter-spacing:4px'>{code}</strong></p>
                           <p>Mã có hiệu lực trong <strong>5 phút</strong>.</p>");
                    StartCooldown();
                }
            }
        }
        finally
        {
            _isResending = false;
        }
    }

    // ── Step 2: Đặt lại mật khẩu ────────────────────────────────
    private async Task HandleResetPassword()
    {
        _isSubmitting = true;
        _otpError     = string.Empty;
        StateHasChanged();

        try
        {
            // 1. Validate OTP
            var (valid, userId, otpErrorMsg) =
                OtpService.ValidateAndConsume(_emailModel.Email, _resetModel.Otp);

            if (!valid)
            {
                _otpError = otpErrorMsg ?? "Mã xác thực không chính xác. Vui lòng kiểm tra lại.";
                return;
            }

            var user = await UserManager.FindByIdAsync(userId!);
            if (user is null)
            {
                _otpError = "Không tìm thấy tài khoản. Vui lòng thử lại.";
                return;
            }

            // 2. Đặt lại mật khẩu qua Identity
            var resetToken = await UserManager.GeneratePasswordResetTokenAsync(user);
            var result     = await UserManager.ResetPasswordAsync(user, resetToken, _resetModel.Password);

            if (!result.Succeeded)
            {
                _otpError = result.Errors.FirstOrDefault()?.Description
                    ?? "Đặt lại mật khẩu thất bại. Vui lòng thử lại.";
                return;
            }

            // 3. Invalidate tất cả Identity cookies đang active
            await UserManager.UpdateSecurityStampAsync(user);

            // 4. Revoke tất cả OpenIddict refresh tokens của user (tích hợp OpenIddict)
            await foreach (var token in TokenManager.FindBySubjectAsync(user.Id))
            {
                await TokenManager.TryRevokeAsync(token);
            }

            _showSuccessModal = true;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    // ── Navigation ───────────────────────────────────────────────
    private void Cancel()       => Navigation.NavigateTo("/account/login");
    private void BackToStep1()  { _step = 1; _step1Alert = string.Empty; }
    private void OnSuccessOk()  { _showSuccessModal = false; Navigation.NavigateTo("/account/login"); }

    // ── Password field manual binding ───────────────────────────
    private void OnPasswordInput(ChangeEventArgs e)
    {
        _resetModel.Password = e.Value?.ToString() ?? string.Empty;
        _editContext2.NotifyFieldChanged(_editContext2.Field(nameof(ResetPasswordModel.Password)));
    }
    private void OnPasswordBlur()
        => _editContext2.NotifyFieldChanged(_editContext2.Field(nameof(ResetPasswordModel.Password)));

    private void OnConfirmPasswordInput(ChangeEventArgs e)
    {
        _resetModel.ConfirmPassword = e.Value?.ToString() ?? string.Empty;
        _editContext2.NotifyFieldChanged(_editContext2.Field(nameof(ResetPasswordModel.ConfirmPassword)));
    }
    private void OnConfirmPasswordBlur()
        => _editContext2.NotifyFieldChanged(_editContext2.Field(nameof(ResetPasswordModel.ConfirmPassword)));

    private string GetPwdCss(string fieldName)
    {
        var fi = _editContext2.Field(fieldName);
        if (!_editContext2.IsModified(fi)) return string.Empty;
        return _editContext2.GetValidationMessages(fi).Any() ? "invalid" : string.Empty;
    }

    // ── Countdown timer ─────────────────────────────────────────
    private void StartCooldown()
    {
        _countdownTimer?.Dispose();
        _resendCooldown = 60;

        _countdownTimer = new System.Threading.Timer(_ =>
        {
            if (_resendCooldown > 0) _resendCooldown--;
            InvokeAsync(StateHasChanged);
            if (_resendCooldown == 0)
            {
                _countdownTimer?.Dispose();
                _countdownTimer = null;
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    public void Dispose() => _countdownTimer?.Dispose();

    // ── SVG eye icon helper ──────────────────────────────────────
    private static RenderFragment EyeIcon(bool open) => open
        ? @<svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
               <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
               <circle cx="12" cy="12" r="3" />
           </svg>
        : @<svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round">
               <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94" />
               <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19" />
               <line x1="1" y1="1" x2="23" y2="23" />
           </svg>;
}
